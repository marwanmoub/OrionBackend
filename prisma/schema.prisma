generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  fullName String?
  phone    String?

  is_email_verified        Boolean   @default(false)
  email_verification_token String?
  email_token_expires_at   DateTime?

  phone_verified          Boolean   @default(false)
  phone_verification_code String?
  phone_code_expires_at   DateTime?

  is_2fa_enabled      Boolean @default(false)
  two_fa_method       String?
  two_fa_secret       String?
  two_fa_backup_codes String?

  last_username_changed DateTime?
  deletion_requested_at DateTime?

  refreshToken String? @unique

  createdAt DateTime @default(now())

  // Relations
  settings         UserSettings?
  chats            ChatParticipant[]
  messages         Message[]
  flights          UserFlight[]
  tickets          Ticket[]
  checklistTasks   ChecklistTask[]
  notifications    Notification[]
  notificationLogs NotificationLog[]
}

model UserSettings {
  id     String @id @default(uuid())
  userId String @unique

  always_use_default_airport      Boolean @default(false)
  delete_old_chats_automatically  Boolean @default(false)
  change_user_state_automatically Boolean @default(false)
  automatedStateManagement        Boolean @default(false)

  user User @relation(fields: [userId], references: [id])
}

model Airport {
  id            String  @id @default(uuid())
  iata_code     String  @unique
  name          String
  city          String
  geo_json_data Json?
  is_default    Boolean @default(false)

  departures Flight[] @relation("DepartureAirport")
  arrivals   Flight[] @relation("ArrivalAirport")
  guides     Guide[]
}

model Flight {
  id            String @id @default(uuid())
  flight_number String @unique

  departure_airport_id String
  arrival_airport_id   String

  scheduled_departure_time DateTime
  expected_departure_time  DateTime?

  gate         String?
  terminal     String?
  status       String
  passcode     String?
  is_cancelled Boolean @default(false)

  // Relations
  departureAirport Airport @relation("DepartureAirport", fields: [departure_airport_id], references: [id])
  arrivalAirport   Airport @relation("ArrivalAirport", fields: [arrival_airport_id], references: [id])

  userFlights      UserFlight[]
  tickets          Ticket[]
  checklistTasks   ChecklistTask[]
  arMarkers        ARMarker[]
  notificationLogs NotificationLog[]
  guides           Guide[]
}

model UserFlight {
  id       String @id @default(uuid())
  userId   String
  flightId String

  user   User   @relation(fields: [userId], references: [id])
  flight Flight @relation(fields: [flightId], references: [id])

  guides         Guide[]
  checklistTasks ChecklistTask[]

  @@unique([userId, flightId])
}

model Ticket {
  id               String   @id @default(uuid())
  userId           String
  flightId         String
  ticketNumber     String?  @unique
  bookingReference String?
  seatNumber       String?
  qrCodePayload    String?
  status           String   @default("ACTIVE")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  flight Flight @relation(fields: [flightId], references: [id])

  @@unique([userId, flightId])
  @@index([flightId])
}

model Guide {
  id                    String   @id @default(uuid())
  flightId              String
  userFlightId          String
  guide_generation_time DateTime

  origin_address          String?  
  origin_lat              Float?   // Latitude
  origin_lng              Float?   // Longitude 

  departure_from_home_time Int?
  departure_from_home_at   DateTime?

  used_airport_id          String?
  guide_pdf_path           String?

  flight     Flight     @relation(fields: [flightId], references: [id])
  userFlight UserFlight @relation(fields: [userFlightId], references: [id])
  airport    Airport?   @relation(fields: [used_airport_id], references: [id])


  @@unique([flightId, userFlightId])
  checklistItems CheckListItem[]
  checklistTasks ChecklistTask[]
}

model CheckListTemplate {
  id                       String  @id @default(uuid())
  taskName                 String
  default_due_offset_hours Int
  is_mandatory             Boolean @default(false)
  item_type                String  @unique

  checklistItems CheckListItem[]
  checklistTasks ChecklistTask[]
}

model CheckListItem {
  id         String  @id @default(uuid())
  guideId    String
  templateId String?

  due_time     DateTime
  is_completed Boolean  @default(false)
  alert_sent   Boolean  @default(false)

  guide    Guide              @relation(fields: [guideId], references: [id])
  template CheckListTemplate? @relation(fields: [templateId], references: [id])
}

enum ChecklistTaskStatus {
  PENDING
  COMPLETE
}

model ChecklistTask {
  id               String              @id @default(uuid())
  userId           String
  flightId         String
  userFlightId     String?
  guideId          String?
  title            String
  itemType         String?
  due_time         DateTime
  dueOffsetMinutes Int?
  posX             Float
  posY             Float
  radiusMeters     Float               @default(5)
  status           ChecklistTaskStatus @default(PENDING)
  alertSent        Boolean             @default(false)
  completedAt      DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  user                User               @relation(fields: [userId], references: [id])
  flight              Flight             @relation(fields: [flightId], references: [id])
  userFlight          UserFlight?        @relation(fields: [userFlightId], references: [id])
  guide               Guide?             @relation(fields: [guideId], references: [id])
  arMarkers           ARMarker[]
  checkListTemplate   CheckListTemplate? @relation(fields: [checkListTemplateId], references: [id])
  checkListTemplateId String?

  @@index([userId, flightId, status])
  @@index([userFlightId])
  @@index([posX, posY])
}

model Location {
  id                 String @id @default(uuid())
  name               String
  geofence_boundary  Json
  state_to_change_to String
}

model StaticQuestions {
  id            String @id @default(uuid())
  category      String
  question_text String
  answer_text   String
}

model Notification {
  id     String @id @default(uuid())
  userId String

  type           String
  title          String
  message        String
  voiceScript    String?
  deepLinkAction String?

  sentAt    DateTime
  createdAt DateTime  @default(now())
  status    String
  readAt    DateTime?

  user User @relation(fields: [userId], references: [id])
}

model NotificationLog {
  id                String   @id @default(uuid())
  userId            String?
  flightId          String?
  type              String
  title             String
  message           String
  reaction_code     String?
  provider          String   @default("OneSignal")
  providerMessageId String?
  payload           Json?
  status            String   @default("PENDING")
  sentAt            DateTime @default(now())
  createdAt         DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id])
  flight Flight? @relation(fields: [flightId], references: [id])

  @@index([userId])
  @@index([flightId])
  @@index([sentAt])
}

model Chat {
  id   String  @id @default(uuid())
  type String
  name String?

  createdAt        DateTime  @default(now())
  last_activity_at DateTime?

  participants ChatParticipant[]
  messages     Message[]
}

model ChatParticipant {
  id     String @id @default(uuid())
  chatId String
  userId String

  isOwner Boolean @default(false)

  chat Chat @relation(fields: [chatId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([chatId, userId])
}

model Message {
  id       String  @id @default(uuid())
  chatId   String
  senderId String?

  sender_type  String
  message_text String
  sentAt       DateTime @default(now())
  is_edited    Boolean  @default(false)

  chat   Chat  @relation(fields: [chatId], references: [id])
  sender User? @relation(fields: [senderId], references: [id])
}

model ArModel {
  id              String   @id @default(uuid())
  slug            String   @unique
  name            String
  description     String?
  category        String
  asset_url       String
  asset_format    String   @default("glb")
  latitude        Float
  longitude       Float
  altitude_meters Float    @default(0)
  position_x      Float    @default(0)
  position_y      Float    @default(0)
  position_z      Float    @default(0)
  rotation_x      Float    @default(0)
  rotation_y      Float    @default(0)
  rotation_z      Float    @default(0)
  scale           Float    @default(1)
  is_active       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([is_active])
  @@index([latitude, longitude])
}

model ARMarker {
  id              String   @id @default(uuid())
  flightId        String?
  checklistTaskId String?
  slug            String   @unique
  name            String
  description     String?
  poiType         String   @default("POI")
  asset_url       String?
  asset_format    String   @default("glb")
  posX            Float
  posY            Float
  posZ            Float    @default(0)
  radiusMeters    Float    @default(5)
  reaction_code   String?
  is_active       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  flight        Flight?        @relation(fields: [flightId], references: [id])
  checklistTask ChecklistTask? @relation(fields: [checklistTaskId], references: [id])

  @@index([flightId])
  @@index([is_active])
  @@index([posX, posY])
}
